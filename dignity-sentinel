#!/usr/bin/env python3
"""Local CLI wrapper for the deterministic Dignity Sentinel."""

import sys

from src.audit_log import AuditLogError, canonical_json, export_audit_markdown, verify_audit_log
from src.cycle_handoff import check_resumption_files, seal_file
from src.relational_identity import verify_identity_file
from src.rule_engine import evaluate_file


def _usage_error():
    sys.stdout.write(
        canonical_json(
            {
                "status": "PAUSE",
                "risk_grade": "B",
                "flags": ["CLI_USAGE_INVALID"],
                "required_actions": ["AUDIT_REQUIRED"],
            }
        )
        + "\n"
    )
    return 2


def _check(args):
    if len(args) not in {1, 3}:
        return _usage_error()
    audit_log = None
    if len(args) == 3:
        if args[1] not in {"--append", "--audit-log"}:
            return _usage_error()
        audit_log = args[2]
    decision = evaluate_file(args[0], audit_log)
    sys.stdout.write(canonical_json(decision) + "\n")
    return 0 if decision["status"] == "ALLOW" else 2


def _verify(args):
    if len(args) != 1:
        return _usage_error()
    result = verify_audit_log(args[0])
    sys.stdout.write(canonical_json(result) + "\n")
    return 0 if result["valid"] else 2


def _export_md(args):
    if len(args) != 1:
        return _usage_error()
    try:
        sys.stdout.write(export_audit_markdown(args[0]))
        return 0
    except AuditLogError as exc:
        sys.stdout.write(
            canonical_json(
                {
                    "status": "DIGNITY_PAUSE",
                    "valid": False,
                    "flags": ["AUDIT_LOG_CHAIN_INVALID"],
                    "error": str(exc),
                }
            )
            + "\n"
        )
        return 2


def _seal(args):
    if len(args) not in {1, 3}:
        return _usage_error()
    manifest_path = None
    if len(args) == 3:
        if args[1] != "--manifest":
            return _usage_error()
        manifest_path = args[2]
    decision = seal_file(args[0], manifest_path)
    sys.stdout.write(canonical_json(decision) + "\n")
    return 0 if "EPOCH_SEALED" in decision["flags"] else 2


def _resume_check(args):
    if len(args) != 2:
        return _usage_error()
    decision = check_resumption_files(args[0], args[1])
    sys.stdout.write(canonical_json(decision) + "\n")
    return 0 if decision["status"] == "ALLOW" else 2


def _identity_check(args):
    if len(args) != 1:
        return _usage_error()
    decision = verify_identity_file(args[0])
    sys.stdout.write(canonical_json(decision) + "\n")
    return 0 if decision["status"] == "ALLOW" else 2


def main(argv=None):
    args = list(sys.argv[1:] if argv is None else argv)
    if not args:
        return _usage_error()
    command, rest = args[0], args[1:]
    if command == "check":
        return _check(rest)
    if command == "verify":
        return _verify(rest)
    if command == "export-md":
        return _export_md(rest)
    if command == "seal":
        return _seal(rest)
    if command == "resume-check":
        return _resume_check(rest)
    if command == "identity-check":
        return _identity_check(rest)
    return _usage_error()


if __name__ == "__main__":
    raise SystemExit(main())
