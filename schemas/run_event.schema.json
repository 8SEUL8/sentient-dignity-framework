{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://sentient-dignity.local/schemas/run_event.schema.json",
  "title": "Dignity Sentinel Run Event",
  "type": "object",
  "additionalProperties": false,
